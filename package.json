{
  "name": "my_addon",
  "version": "1.0.0",
  "description": "Contains skeleton code to generate a native addon based on node-addon-api",
  "binary": {
    "napi_versions": [
      9
    ]
  },
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "clean": "cmake-js clean",
    "configure": "cmake-js configure -G Ninja --CDCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    "build": "cmake-js build -G Ninja --CDCMAKE_EXPORT_COMPILE_COMMANDS=ON",
    "rebuild": "cmake-js rebuild -G Ninja",
    "test": "node __test__/test.js"
  },
  "dependencies": {
    "node-addon-api": "*"
  },
  "devDependencies": {
    "cmake-js": "*"
  },
  "packageManager": "pnpm@10.12.4+sha512.5ea8b0deed94ed68691c9bad4c955492705c5eeb8a87ef86bc62c74a26b037b08ff9570f108b2e4dbd1dd1a9186fea925e527f141c648e85af45631074680184"
}
